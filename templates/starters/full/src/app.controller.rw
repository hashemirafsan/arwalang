#[injectable]
#[controller("/")]
class AppController {
  constructor(
    auth: AuthService,
    db: DatabaseService,
    logger: LoggerService,
  ) {}

  #[get("/")]
  fn status(res: Result<String, HttpError>): Result<String, HttpError> {
    return res
  }

  #[post("/users")]
  fn createUser(res: Result<String, HttpError>, #[body] dto: CreateUserDto): Result<String, HttpError> {
    return res
  }
}
